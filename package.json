{
  "name": "kursy-app-modern",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 5000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "e2e:install": "playwright install",
    "e2e:install:ci": "playwright install --with-deps",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:seed": "node tests/e2e/scripts/seed-db.mjs seed",
    "e2e:seed:reset": "node tests/e2e/scripts/seed-db.mjs reset",
    "e2e:seed:all": "node tests/e2e/scripts/seed-db.mjs all",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@fontsource/open-sans": "^5.2.7",
    "@pdf-lib/fontkit": "^1.1.1",
    "@stripe/stripe-js": "^7.2.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "clsx": "^2.1.1",
    "next": "15.3.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "server-only": "^0.0.1",
    "stripe": "^18.0.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@playwright/test": "^1.41.2",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "jsdom": "^23.0.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
